{
  "manifest_version": 3,
  "name": "Daily Planner Inbox",
  "version": "1.0",
  "description": "Save any link to your Daily Planner inbox with one click.",
  "permissions": ["activeTab", "contextMenus"],
  "host_permissions": ["https://dailyplanner-zus3.onrender.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Save to Inbox"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16":  "icon16.png",
    "48":  "icon48.png",
    "128": "icon128.png"
  }
}
